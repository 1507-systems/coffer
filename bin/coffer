#!/usr/bin/env bash
# coffer -- Offline encrypted secrets vault CLI
# Dispatches subcommands to lib/ scripts using SOPS + age for encryption.
set -euo pipefail

# Resolve the coffer root directory (parent of bin/). This is the TOOL repo,
# not the vault repo. The two are intentionally separated since April 2026:
# the tool is public (1507-systems/coffer), the vault is private
# (bryce-shashinka/coffer-vault). COFFER_ROOT is only needed to find lib/ files.
COFFER_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export COFFER_ROOT

# Source shared helpers (die, warn, log, require_cmd, ntfy, etc.)
# shellcheck source=../lib/common.sh
source "${COFFER_ROOT}/lib/common.sh"

# Source the auto-commit-and-push helper. This defines auto_sync_push(), which
# is called at the end of every state-modifying command so that origin/main
# always reflects the latest vault/recipient state. See lib/git-sync.sh for
# the escape hatch (COFFER_AUTO_SYNC=0) and branch-safety behavior.
# shellcheck source=../lib/git-sync.sh
source "${COFFER_ROOT}/lib/git-sync.sh"

# Source the doctor/preflight helpers. This defines cmd_doctor() (the audit
# subcommand) and preflight_recipient_check() (called before writes). See
# lib/doctor.sh for the drift-detection logic.
# shellcheck source=../lib/doctor.sh
source "${COFFER_ROOT}/lib/doctor.sh"

# --- Vault location resolution ---
#
# COFFER_VAULT_ROOT is the top-level directory of the private vault repo
# (e.g., bryce-shashinka/coffer-vault). It defaults to ~/dev/coffer-vault
# but can be overridden via the environment to point at any directory.
# This separation keeps the open-source tool code in one git repo and
# the private encrypted data in another.
#
# How to set up the vault repo: see README.md.
_resolve_vault_root() {
    local default_root="${HOME}/dev/coffer-vault"
    local requested_root="${COFFER_VAULT_ROOT:-${default_root}}"

    if [[ -d "$requested_root" ]]; then
        # Vault exists at the requested location.
        printf '%s' "$requested_root"
        return 0
    fi

    # If the caller explicitly set COFFER_VAULT_ROOT to a path that doesn't
    # exist, that is a misconfiguration. Die rather than silently using a
    # different vault.
    if [[ -n "${COFFER_VAULT_ROOT:-}" ]]; then
        echo "coffer: error: COFFER_VAULT_ROOT='${COFFER_VAULT_ROOT}' does not exist." >&2
        echo "coffer:        Clone or create your vault repo and point COFFER_VAULT_ROOT at it." >&2
        echo "coffer:        See README.md for setup instructions." >&2
        exit 1
    fi

    # Default location does not exist. Guide the user to set up a vault repo.
    echo "coffer: error: No vault found at default location: ${default_root}" >&2
    echo "coffer:        Create a private git repo for your vault, clone it to ~/dev/coffer-vault," >&2
    echo "coffer:        and set: export COFFER_VAULT_ROOT=\$HOME/dev/coffer-vault" >&2
    echo "coffer:        See README.md for full setup instructions." >&2
    exit 1
}

# Resolve vault root once; export so lib/ scripts inherit it.
COFFER_VAULT_ROOT="$(_resolve_vault_root)"
export COFFER_VAULT_ROOT

# Coffer configuration paths.
# COFFER_CONFIG_DIR is machine-specific (identity, session key) and stays in
# ~/.config/coffer regardless of vault location. The vault-adjacent paths
# (COFFER_VAULT, COFFER_SOPS_CONFIG) are derived from COFFER_VAULT_ROOT.
#
# Using the ${VAR:-default} idiom is critical: unconditional exports used to
# clobber COFFER_SESSION_KEY mid-flight, which meant tests that passed
# COFFER_SESSION_KEY in the environment were actually reading the caller's
# real ~/.config/coffer/.session-key. That produced false-positive passes and
# made the session-key override useless outside the dispatcher.
export COFFER_CONFIG_DIR="${COFFER_CONFIG_DIR:-${HOME}/.config/coffer}"
export COFFER_VAULT="${COFFER_VAULT:-${COFFER_VAULT_ROOT}/vault}"
export COFFER_SOPS_CONFIG="${COFFER_SOPS_CONFIG:-${COFFER_VAULT_ROOT}/config/.sops.yaml}"
export COFFER_SESSION_KEY="${COFFER_SESSION_KEY:-${COFFER_CONFIG_DIR}/.session-key}"

usage() {
    cat <<'EOF'
Usage: coffer <command> [args...]

Commands:
  get    <category/key>         Retrieve a secret (prints to stdout)
  set    <category/key> [value] Store or update a secret
  list   [category]             List categories and keys
  edit   <category>             Edit a category file interactively
  import <csv-file>             Import secrets from a keychain CSV dump
  init   [--force]              First-time setup (generate age keypair; writes
                                ~/.config/coffer/.session-key). Refuses to
                                overwrite an existing identity unless --force.
  unlock [--auto]               Print `export SOPS_AGE_KEY=...` for
                                `eval $(coffer unlock)`. --auto is a no-op
                                kept for LaunchAgent backward compatibility.
  lock                          Emit `unset SOPS_AGE_KEY`. Does NOT delete
                                the session-key file (the file is the
                                persistent identity store; see lock.sh).
  add-recipient <age-pubkey>    Add an age public key and re-encrypt vault
  onboard                       Bootstrap this machine: generate identity (if
                                needed) and drop pubkey into vault/ for the
                                vault repo to carry to the trusted machine.
                                Run on the NEW machine.
  finalize-onboard              Consume pending-recipient files from
                                vault/.pending-recipient-*.pub, call
                                add-recipient for each, delete handled files.
                                Run on an ALREADY-TRUSTED machine (Wiles).
  refresh                       Pull latest vault changes from origin/main
                                (git fetch + push any local-only commits, then
                                pull --rebase). Pushes unpushed local commits
                                before rebasing so diverged branches are never
                                left in a deadlocked state. Use in SessionStart
                                hooks to keep the vault current. Safe to run
                                when the vault is already up to date.
                                (alias: sync-pull — deprecated, prints a
                                warning; existing scripts continue to work)
  doctor                        Read-only vault state audit. Checks that every
                                encrypted vault file's recipient list matches
                                config/.sops.yaml, that this machine's identity
                                appears in the list, and that the vault git
                                repo is clean and up to date with origin/main.
                                Exit 0 = all clear. Exit 1 = drift found.

Options:
  -h, --help    Show this help message
  -v, --version Show version

Environment:
  COFFER_VAULT_ROOT    Path to the private vault repo root. Defaults to
                       ~/dev/coffer-vault. Set this in ~/.zshrc.local so every
                       session finds the vault without the deprecated in-repo
                       fallback. Example: export COFFER_VAULT_ROOT=$HOME/dev/coffer-vault
  COFFER_AUTO_SYNC=0   Disable the automatic git commit+push that runs after
                       every state-modifying command (set, edit, import,
                       add-recipient, finalize-onboard, init). Useful for CI
                       runs, test sandboxes, and one-shot automation.
                       Default: enabled (auto-sync on).

EOF
}

version() {
    echo "coffer 1.0.0"
}

# cmd_refresh -- Pull latest vault changes from the vault repo origin/main.
# This is the canonical user-facing name (primary alias: `coffer refresh`).
# `coffer sync-pull` is a deprecated alias that prints a deprecation warning
# and then calls this function so existing scripts and SessionStart hooks
# continue to work without modification during the rollout period.
#
# Strategy (hardened April 2026):
#   - Detects local commits not yet pushed (from a prior session that ended
#     before auto_sync_push completed) and pushes them first.
#   - Uses --rebase instead of --ff-only so that if the vault somehow has a
#     local-only commit AND origin has advanced, the local commit rides on top
#     rather than causing a diverged-branch deadlock.
#   - Rebase conflicts in encrypted vault files are NOT auto-resolvable.
#     If the rebase fails, we abort it and die() loudly. The hook calling
#     refresh will surface the error so the user sees it at session start
#     (far better than a silent stale vault).
cmd_refresh() {
    if ! command -v git >/dev/null 2>&1; then
        die "git not found on PATH: cannot sync vault"
    fi

    # Refuse to pull if the working tree has uncommitted coffer-managed changes.
    # This prevents a pull from being silently blocked by a dirty tree, which
    # would leave the session running on stale vault data without any error.
    local dirty
    dirty=$(git -C "$COFFER_VAULT_ROOT" status --porcelain \
        -- config/.sops.yaml vault/ 2>/dev/null || echo "")
    if [[ -n "$dirty" ]]; then
        warn "refresh: vault has uncommitted local changes; skipping pull"
        warn "  commit or stash changes first, then re-run: coffer refresh"
        return 0
    fi

    # Check whether the upstream is configured before trying to pull.
    local upstream
    upstream=$(git -C "$COFFER_VAULT_ROOT" rev-parse --abbrev-ref '@{u}' 2>/dev/null || echo "")
    if [[ -z "$upstream" ]]; then
        warn "refresh: no upstream configured for vault repo; skipping pull"
        warn "  run: git -C ${COFFER_VAULT_ROOT} push -u origin main"
        return 0
    fi

    # Fetch first to get an accurate ahead/behind picture.
    git -C "$COFFER_VAULT_ROOT" fetch origin 2>/dev/null || {
        warn "refresh: fetch from origin failed (offline?); using cached state"
    }

    # If there are local commits not yet on origin (prior session ended before
    # push completed), push them now before the pull-rebase so origin/main
    # includes our previous work before we integrate new remote commits.
    local ahead
    ahead=$(git -C "$COFFER_VAULT_ROOT" rev-list --count '@{u}..HEAD' 2>/dev/null || echo 0)
    if [[ "$ahead" -gt 0 ]]; then
        log "refresh: ${ahead} local commit(s) not yet pushed; pushing before pull"
        if ! git -C "$COFFER_VAULT_ROOT" push 2>/dev/null; then
            warn "refresh: push of ${ahead} local commit(s) failed"
            warn "  resolve manually: git -C ${COFFER_VAULT_ROOT} push"
        fi
    fi

    local behind
    behind=$(git -C "$COFFER_VAULT_ROOT" rev-list --count 'HEAD..@{u}' 2>/dev/null || echo 0)
    if [[ "$behind" -eq 0 ]]; then
        log "refresh: vault is up to date with origin"
        return 0
    fi

    # Resolve the remote branch name from the tracked upstream (e.g., origin/main
    # -> "main"). Avoids hardcoding "main" in case the vault repo uses a
    # different default branch name.
    local remote_branch
    remote_branch=$(git -C "$COFFER_VAULT_ROOT" rev-parse --abbrev-ref '@{u}' 2>/dev/null \
        | sed 's|^[^/]*/||')
    remote_branch="${remote_branch:-main}"

    log "refresh: ${behind} commit(s) behind origin/${remote_branch} -- pulling"

    # Use --rebase so that if a local commit somehow exists alongside remote
    # commits (unusual but possible), it rides on top cleanly instead of
    # producing a merge commit or a ff-only refusal.
    local pull_output
    if pull_output=$(git -C "$COFFER_VAULT_ROOT" pull --rebase origin "$remote_branch" 2>&1); then
        log "refresh: synced ${behind} commit(s) from origin/${remote_branch}"
    else
        # Rebase conflict in an encrypted vault file: auto-resolution is
        # dangerous (conflict markers inside SOPS YAML corrupt the file).
        # Abort the rebase and surface the error loudly.
        git -C "$COFFER_VAULT_ROOT" rebase --abort 2>/dev/null || true
        die "refresh: pull --rebase failed (conflict in encrypted vault?):
${pull_output}
coffer:  Manual resolution required. Run:
coffer:    git -C ${COFFER_VAULT_ROOT} status
coffer:  Then inspect and resolve conflicting files before retrying."
    fi
}

# cmd_sync_pull -- Deprecated alias for cmd_refresh.
# Prints a one-line deprecation notice on stderr so users know to update
# scripts, then delegates to cmd_refresh unchanged. `sync-pull` will continue
# to work indefinitely; removal requires a separate explicit decision.
cmd_sync_pull() {
    echo "coffer: 'sync-pull' is deprecated; use 'coffer refresh' instead" >&2
    cmd_refresh "$@"
}

# Require at least one argument
if [[ $# -lt 1 ]]; then
    usage >&2
    die "No command specified"
fi

command="$1"
shift

case "$command" in
    get)
        # shellcheck source=../lib/get.sh
        source "${COFFER_ROOT}/lib/get.sh"
        cmd_get "$@"
        ;;
    set)
        # shellcheck source=../lib/set.sh
        source "${COFFER_ROOT}/lib/set.sh"
        # Pull-rebase from origin BEFORE the write so that if origin advanced
        # since SessionStart (the other machine pushed in the interim), we
        # incorporate those commits first. This eliminates the drift window
        # that caused the April 2026 non-fast-forward push rejection on Verve.
        auto_sync_pull
        # Run preflight drift check before any write. If .sops.yaml and vault
        # file recipients are out of sync, the write is aborted with a clear
        # error pointing to `coffer doctor`. This prevents accumulating new
        # secrets on top of an already-drifted vault.
        preflight_recipient_check
        cmd_set "$@"
        # Commit the vault change. The first positional arg is always the path
        # (category/key); extracting just that keeps the commit message safe
        # even if the value was passed on the command line.
        auto_sync_push "set ${1:-unknown}"
        ;;
    list)
        # shellcheck source=../lib/list.sh
        source "${COFFER_ROOT}/lib/list.sh"
        cmd_list "$@"
        ;;
    edit)
        # shellcheck source=../lib/edit.sh
        source "${COFFER_ROOT}/lib/edit.sh"
        # Pull-rebase before opening the editor for the same reason as `set`:
        # if origin advanced since SessionStart, get those commits before we
        # write to avoid a post-edit push rejection.
        auto_sync_pull
        # Run preflight drift check before opening the editor. If recipients
        # are drifted, the edit is aborted before SOPS tries to decrypt.
        preflight_recipient_check
        cmd_edit "$@"
        # Commit using the category name (first arg).
        auto_sync_push "edit ${1:-unknown}"
        ;;
    import)
        # shellcheck source=../lib/import.sh
        source "${COFFER_ROOT}/lib/import.sh"
        # Pull-rebase before a bulk import for the same reason as `set`.
        auto_sync_pull
        cmd_import "$@"
        # Commit using the CSV basename so the history shows which file was imported.
        # `local` is not valid at top-level script scope (only inside functions),
        # so we use a plain variable with an underscore prefix to signal it is
        # short-lived and not part of the exported environment.
        _coffer_import_csv_basename=$(basename "${1:-unknown.csv}")
        auto_sync_push "import secrets from ${_coffer_import_csv_basename}"
        ;;
    init)
        # shellcheck source=../lib/init.sh
        source "${COFFER_ROOT}/lib/init.sh"
        cmd_init "$@"
        # Commit .sops.yaml if init wrote it. init is usually the very first
        # git operation on the repo, so there may be no remote yet -- auto_sync_push
        # handles that gracefully (logs warning, returns 0).
        auto_sync_push "init vault"
        ;;
    unlock)
        # shellcheck source=../lib/unlock.sh
        source "${COFFER_ROOT}/lib/unlock.sh"
        cmd_unlock "$@"
        ;;
    lock)
        # shellcheck source=../lib/lock.sh
        source "${COFFER_ROOT}/lib/lock.sh"
        cmd_lock "$@"
        ;;
    add-recipient)
        # shellcheck source=../lib/add-recipient.sh
        source "${COFFER_ROOT}/lib/add-recipient.sh"
        cmd_add_recipient "$@"
        # Commit .sops.yaml + re-encrypted vault files. Include a prefix of the
        # pubkey in the message for traceability (full key is fine too, it is not secret).
        auto_sync_push "add recipient ${1:-unknown}"
        ;;
    onboard)
        # shellcheck source=../lib/onboard.sh
        source "${COFFER_ROOT}/lib/onboard.sh"
        cmd_onboard "$@"
        ;;
    finalize-onboard)
        # shellcheck source=../lib/onboard.sh
        source "${COFFER_ROOT}/lib/onboard.sh"
        cmd_finalize_onboard "$@"
        auto_sync_push "finalize-onboard"
        ;;
    refresh)
        cmd_refresh "$@"
        ;;
    sync-pull)
        # Deprecated alias for `refresh`. Prints a warning and delegates.
        cmd_sync_pull "$@"
        ;;
    doctor)
        cmd_doctor "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    -v|--version|version)
        version
        ;;
    *)
        usage >&2
        die "Unknown command: ${command}"
        ;;
esac
