#!/usr/bin/env bash
# coffer -- Offline encrypted secrets vault CLI
# Dispatches subcommands to lib/ scripts using SOPS + age for encryption.
set -euo pipefail

# Resolve the coffer root directory (parent of bin/)
COFFER_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export COFFER_ROOT

# Source shared helpers (die, warn, log, require_cmd, ntfy, etc.)
# shellcheck source=../lib/common.sh
source "${COFFER_ROOT}/lib/common.sh"

# Coffer configuration paths.
# These default to the usual per-user locations but respect pre-set values
# so tests, sandboxes, and alternative configs can override them. Using the
# ${VAR:-default} idiom instead of unconditional assignment is critical:
# unconditional exports used to clobber COFFER_SESSION_KEY mid-flight, which
# meant tests that passed COFFER_SESSION_KEY in the environment were
# actually reading the caller's real ~/.config/coffer/.session-key. That
# produced false-positive passes and made the session-key override useless
# outside the dispatcher.
export COFFER_CONFIG_DIR="${COFFER_CONFIG_DIR:-${HOME}/.config/coffer}"
export COFFER_VAULT="${COFFER_VAULT:-${COFFER_ROOT}/vault}"
export COFFER_SOPS_CONFIG="${COFFER_SOPS_CONFIG:-${COFFER_ROOT}/config/.sops.yaml}"
export COFFER_SESSION_KEY="${COFFER_SESSION_KEY:-${COFFER_CONFIG_DIR}/.session-key}"

usage() {
    cat <<'EOF'
Usage: coffer <command> [args...]

Commands:
  get    <category/key>         Retrieve a secret (prints to stdout)
  set    <category/key> [value] Store or update a secret
  list   [category]             List categories and keys
  edit   <category>             Edit a category file interactively
  import <csv-file>             Import secrets from a keychain CSV dump
  init   [--force]              First-time setup (generate age keypair; writes
                                ~/.config/coffer/.session-key). Refuses to
                                overwrite an existing identity unless --force.
  unlock [--auto]               Print `export SOPS_AGE_KEY=...` for
                                `eval $(coffer unlock)`. --auto is a no-op
                                kept for LaunchAgent backward compatibility.
  lock                          Emit `unset SOPS_AGE_KEY`. Does NOT delete
                                the session-key file (the file is the
                                persistent identity store; see lock.sh).
  add-recipient <age-pubkey>    Add an age public key and re-encrypt vault

Options:
  -h, --help    Show this help message
  -v, --version Show version

EOF
}

version() {
    echo "coffer 1.0.0"
}

# Require at least one argument
if [[ $# -lt 1 ]]; then
    usage >&2
    die "No command specified"
fi

command="$1"
shift

case "$command" in
    get)
        # shellcheck source=../lib/get.sh
        source "${COFFER_ROOT}/lib/get.sh"
        cmd_get "$@"
        ;;
    set)
        # shellcheck source=../lib/set.sh
        source "${COFFER_ROOT}/lib/set.sh"
        cmd_set "$@"
        ;;
    list)
        # shellcheck source=../lib/list.sh
        source "${COFFER_ROOT}/lib/list.sh"
        cmd_list "$@"
        ;;
    edit)
        # shellcheck source=../lib/edit.sh
        source "${COFFER_ROOT}/lib/edit.sh"
        cmd_edit "$@"
        ;;
    import)
        # shellcheck source=../lib/import.sh
        source "${COFFER_ROOT}/lib/import.sh"
        cmd_import "$@"
        ;;
    init)
        # shellcheck source=../lib/init.sh
        source "${COFFER_ROOT}/lib/init.sh"
        cmd_init "$@"
        ;;
    unlock)
        # shellcheck source=../lib/unlock.sh
        source "${COFFER_ROOT}/lib/unlock.sh"
        cmd_unlock "$@"
        ;;
    lock)
        # shellcheck source=../lib/lock.sh
        source "${COFFER_ROOT}/lib/lock.sh"
        cmd_lock "$@"
        ;;
    add-recipient)
        # shellcheck source=../lib/add-recipient.sh
        source "${COFFER_ROOT}/lib/add-recipient.sh"
        cmd_add_recipient "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    -v|--version|version)
        version
        ;;
    *)
        usage >&2
        die "Unknown command: ${command}"
        ;;
esac
